    <general name="KNEE_PITCH_L"   joint="KNEE_PITCH_L"   gainprm="35 0 0" biastype="affine" biasprm="0 -35 -7" forcerange="-180 180"/>
    <general name="ANKLE_PITCH_L"  joint="ANKLE_PITCH_L"  gainprm="20 0 0" biastype="affine" biasprm="0 -20 -3" forcerange="-40  40"/>
    <general name="ANKLE_ROLL_L"   joint="ANKLE_ROLL_L"   gainprm="20 0 0" biastype="affine" biasprm="0 -20 -3" forcerange="-40  40"/>
