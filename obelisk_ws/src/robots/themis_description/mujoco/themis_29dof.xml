    <general name="WRIST_YAW_R"      joint="WRIST_YAW_R"      gainprm="15 0 0" biastype="affine" biasprm="0 -15 -2" forcerange="-20 20"/>
    <!-- Left arm -->
    <general name="SHOULDER_PITCH_L" joint="SHOULDER_PITCH_L" gainprm="15 0 0" biastype="affine" biasprm="0 -15 -2" forcerange="-20 20"/>
    <general name="SHOULDER_ROLL_L"  joint="SHOULDER_ROLL_L"  gainprm="15 0 0" biastype="affine" biasprm="0 -15 -2" forcerange="-20 20"/>
    <general name="SHOULDER_YAW_L"   joint="SHOULDER_YAW_L"   gainprm="15 0 0" biastype="affine" biasprm="0 -15 -2" forcerange="-20 20"/>
    <general name="ELBOW_PITCH_L"    joint="ELBOW_PITCH_L"    gainprm="15 0 0" biastype="affine" biasprm="0 -15 -2" forcerange="-20 20"/>
    <general name="ELBOW_YAW_L"      joint="ELBOW_YAW_L"      gainprm="15 0 0" biastype="affine" biasprm="0 -15 -2" forcerange="-20 20"/>
    <general name="WRIST_PITCH_L"    joint="WRIST_PITCH_L"    gainprm="15 0 0" biastype="affine" biasprm="0 -15 -2" forcerange="-20 20"/>
